```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db
```